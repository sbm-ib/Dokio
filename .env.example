# Supabase — récupère ces valeurs dans ton projet Supabase > Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — récupère ta clé sur console.anthropic.com
# NE JAMAIS commiter la vraie clé — ajoute-la dans Vercel > Settings > Environment Variables
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Stripe — récupère ces valeurs sur dashboard.stripe.com (mode test d'abord)
# NE JAMAIS commiter les vraies valeurs — ajoute-les dans Vercel > Settings > Environment Variables
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PREMIUM=price_xxxxxxxxxxxxxxxxxxxx

# Resend — récupère ta clé sur resend.com (compte gratuit) — mode TEST pour les rappels email
# NE JAMAIS commiter la vraie clé — ajoute-la dans Vercel > Settings > Environment Variables
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# TEST_EMAIL doit être l'adresse avec laquelle tu t'es inscrit sur Resend
# (en gratuit sans domaine vérifié, Resend n'autorise l'envoi qu'à cette adresse)
TEST_EMAIL=ton-adresse@example.com
